# Copy this file to ".env.local" and fill in the values from Supabase.
# I (Claude) will walk you through where to find each one in Phase 2.
# NEVER share the values of this file in a chat or commit them to GitHub.

# Public — safe to expose in the browser:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — used only on the server, never sent to the browser:
SUPABASE_SERVICE_ROLE_KEY=

# Secret — for AI comment moderation (auto-approve mode). Optional:
# if blank, auto-mode comments fall back to manual review.
ANTHROPIC_API_KEY=
